import { parse } from "stdlib/json.cxy"

@json
struct Address {
    line1: String = null
}

@json
struct User[...T] {
    name: String = null
    address = Address{}
    func `init`() {
        info!("type of T is {t}", #T)
    }
}

func hello[T, U, ...Z](y: U, ...x: auto) {
    println(x)
}
func main(): !void {
    hello[i32, i32](10, 20)
}
