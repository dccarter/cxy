#!/bin/bash
# git-release - Manage Git repository releases
#
# Tool for creating, listing, and deleting GitHub releases

set -euo pipefail

# Color definitions
reset='\033[0m'
red='\033[0;31m'
green='\033[0;32m'
yellow='\033[0;33m'
blue='\033[0;34m'
cyan='\033[0;36m'
white='\033[0;37m'

Bred='\033[1;31m'
Bgreen='\033[1;32m'
Byellow='\033[1;33m'
Bblue='\033[1;34m'
Bcyan='\033[1;36m'
Bwhite='\033[1;37m'

# Configuration
GITHUB_REPO="${GITHUB_REPO:-}"
GIT_REMOTE="${GIT_REMOTE:-origin}"
GITHUB_TOKEN="${GITHUB_TOKEN:-}"

# Command state
COMMAND=""
DRY_RUN=false
FORCE=false
VERBOSE=false
USE_GH_CLI=false

usage() {
    cat << EOF
Usage: $(basename "$0") <command> [options]

Manage GitHub releases (tags and releases) for any repository

COMMANDS:
    list [pattern]              List releases (optionally filter by pattern)
    create <version> [message]  Create a new release
    delete <version>            Delete a release
    show <version>              Show release details

OPTIONS:
    --dry-run                   Show what would happen without making changes
    --force                     Skip confirmation prompts
    --verbose                   Show detailed output
    --local                     List only local tags (with 'list' command)
    --remote                    List only remote tags (with 'list' command)
    --message, -m <msg>         Release message (with 'create' command)
    --repo <owner/repo>         GitHub repository (required, or auto-detect from git remote)
    --remote-name <name>        Git remote name (default: origin)
    -h, --help                  Show this help message

ENVIRONMENT VARIABLES:
    GITHUB_REPO        GitHub repository (owner/repo format, or auto-detected)
    GIT_REMOTE         Git remote name (default: origin)
    GITHUB_TOKEN       GitHub API token (required for delete/show)

EXAMPLES:
    # List all releases
    $(basename "$0") list

    # List releases matching pattern
    $(basename "$0") list "v0.1.*"

    # Create a new release
    $(basename "$0") create v0.1.5 -m "Bug fixes and improvements"

    # Delete a release (with confirmation)
    $(basename "$0") delete v0.1.4

    # Delete a release without confirmation
    $(basename "$0") delete v0.1.4 --force

    # Show release details
    $(basename "$0") show v0.1.5

    # Dry run to see what would happen
    $(basename "$0") create v0.1.5 --dry-run

EOF
    exit 0
}

log() {
    if [ "$VERBOSE" = true ]; then
        echo -e "${Bblue}[LOG]${reset} $1"
    fi
}

info() {
    echo -e "${Bgreen}✓${reset} $1"
}

warn() {
    echo -e "${Byellow}⚠${reset} $1"
}

error() {
    echo -e "${Bred}error${reset}: $1" >&2
    exit 1
}

confirm() {
    if [ "$FORCE" = true ]; then
        return 0
    fi

    local message="$1"
    echo -e "${Byellow}⚠${reset} $message"
    read -p "Continue? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Cancelled."
        exit 1
    fi
}

check_git_repo() {
    if ! git rev-parse --git-dir > /dev/null 2>&1; then
        error "Not in a git repository"
    fi
}

check_remote_exists() {
    if ! git remote get-url "$GIT_REMOTE" > /dev/null 2>&1; then
        error "Git remote '$GIT_REMOTE' not found"
    fi
}

detect_github_repo() {
    if [ -n "$GITHUB_REPO" ]; then
        return 0
    fi

    # Try to auto-detect from git remote
    check_remote_exists
    local remote_url=$(git remote get-url "$GIT_REMOTE" 2>/dev/null || echo "")

    if [ -z "$remote_url" ]; then
        error "Cannot auto-detect repository. Please specify with --repo or set GITHUB_REPO"
    fi

    # Parse GitHub URL (supports both SSH and HTTPS)
    # git@github.com:owner/repo.git -> owner/repo
    # https://github.com/owner/repo.git -> owner/repo
    if echo "$remote_url" | grep -q "github.com"; then
        GITHUB_REPO=$(echo "$remote_url" | sed -E 's#.*github\.com[:/]([^/]+/[^/]+)(\.git)?$#\1#' | sed 's/\.git$//')
        log "Auto-detected repository: $GITHUB_REPO"
    else
        error "Remote URL is not a GitHub repository: $remote_url"
    fi

    if [ -z "$GITHUB_REPO" ] || ! echo "$GITHUB_REPO" | grep -q '/'; then
        error "Failed to parse GitHub repository from remote URL: $remote_url"
    fi
}

validate_version() {
    local version="$1"

    # Check if version starts with 'v' and follows semver pattern
    if ! echo "$version" | grep -qE '^v[0-9]+\.[0-9]+\.[0-9]+$'; then
        error "Invalid version format: $version (expected format: v0.1.0)"
    fi
}

check_gh_cli() {
    if command -v gh > /dev/null 2>&1; then
        USE_GH_CLI=true
        log "Using GitHub CLI (gh)"
    else
        log "GitHub CLI not found, will use API"
        USE_GH_CLI=false
    fi
}

check_github_auth() {
    if [ "$USE_GH_CLI" = true ]; then
        if ! gh auth status > /dev/null 2>&1; then
            error "GitHub CLI not authenticated. Run: gh auth login"
        fi
    else
        if [ -z "$GITHUB_TOKEN" ]; then
            error "GITHUB_TOKEN environment variable not set"
        fi
    fi
}

# List releases
cmd_list() {
    local pattern="${1:-v*}"
    local show_local=true
    local show_remote=true

    # Parse list-specific options
    while [[ $# -gt 0 ]]; do
        case $1 in
            --local)
                show_remote=false
                shift
                ;;
            --remote)
                show_local=false
                shift
                ;;
            *)
                pattern="$1"
                shift
                ;;
        esac
    done

    check_git_repo
    detect_github_repo

    if [ "$show_local" = true ]; then
        echo -e "${Bwhite}Local Tags:${reset}"
        if git tag -l "$pattern" | grep -q .; then
            git tag -l "$pattern" | while read -r tag; do
                local commit=$(git rev-list -n 1 "$tag" 2>/dev/null || echo "unknown")
                local date=$(git log -1 --format=%ai "$tag" 2>/dev/null || echo "unknown")
                echo -e "  ${Bgreen}$tag${reset} (${commit:0:7}) - $date"
            done
        else
            echo "  No local tags matching '$pattern'"
        fi
        echo ""
    fi

    if [ "$show_remote" = true ]; then
        check_remote_exists
        echo -e "${Bwhite}Remote Tags (${GIT_REMOTE}):${reset}"
        if git ls-remote --tags "$GIT_REMOTE" | grep -E "refs/tags/${pattern}" | grep -v '\^{}' > /dev/null; then
            git ls-remote --tags "$GIT_REMOTE" | grep -E "refs/tags/${pattern}" | grep -v '\^{}' | while read -r hash ref; do
                local tag=${ref#refs/tags/}
                echo -e "  ${Bcyan}$tag${reset} (${hash:0:7})"
            done
        else
            echo "  No remote tags matching '$pattern'"
        fi
        echo ""
    fi

    # Show GitHub releases if we can
    if [ "$USE_GH_CLI" = true ]; then
        echo -e "${Bwhite}GitHub Releases:${reset}"
        if gh release list --repo "$GITHUB_REPO" --limit 100 2>/dev/null | grep -E "$pattern" > /dev/null; then
            gh release list --repo "$GITHUB_REPO" --limit 100 | grep -E "$pattern" || echo "  No releases matching '$pattern'"
        else
            echo "  No releases matching '$pattern'"
        fi
    fi
}

# Create a release
cmd_create() {
    local version="$1"
    local message="${2:-Release $version}"

    if [ -z "$version" ]; then
        error "Version required. Usage: $(basename "$0") create <version> [message]"
    fi

    validate_version "$version"
    check_git_repo
    check_remote_exists
    detect_github_repo

    # Check if tag already exists locally
    if git rev-parse "$version" >/dev/null 2>&1; then
        error "Tag $version already exists locally"
    fi

    # Check if tag exists on remote
    if git ls-remote --tags "$GIT_REMOTE" | grep -q "refs/tags/$version"; then
        error "Tag $version already exists on remote"
    fi

    # Check for uncommitted changes
    if [ -n "$(git status --porcelain)" ]; then
        warn "You have uncommitted changes in your working directory"
        confirm "Create release anyway?"
    fi

    local current_branch=$(git branch --show-current)
    local current_commit=$(git rev-parse HEAD)

    if [ "$DRY_RUN" = true ]; then
        echo -e "${Byellow}=== DRY RUN MODE ===${reset}"
        echo -e "${Bblue}Would create release:${reset}"
        echo "  Version: $version"
        echo "  Message: $message"
        echo "  Branch: $current_branch"
        echo "  Commit: ${current_commit:0:7}"
        echo "  Remote: $GIT_REMOTE"
        echo ""
        echo -e "${Bwhite}Commands that would be executed:${reset}"
        echo "  git tag -a $version -m \"$message\""
        echo "  git push $GIT_REMOTE $version"
        return 0
    fi

    info "Creating release $version on branch $current_branch (${current_commit:0:7})"

    # Create annotated tag
    log "Creating annotated tag: $version"
    git tag -a "$version" -m "$message"

    # Push tag to remote
    log "Pushing tag to $GIT_REMOTE"
    git push "$GIT_REMOTE" "$version"

    info "Successfully created and pushed tag: $version"
    echo ""
    echo -e "${Bwhite}Next steps:${reset}"
    echo "  1. GitHub Actions will build the release"
    echo "  2. Monitor workflow at: https://github.com/$GITHUB_REPO/actions"
    echo "  3. Release will appear at: https://github.com/$GITHUB_REPO/releases/tag/$version"
}

# Delete a release
cmd_delete() {
    local version="$1"

    if [ -z "$version" ]; then
        error "Version required. Usage: $(basename "$0") delete <version>"
    fi

    validate_version "$version"
    check_git_repo
    check_remote_exists
    detect_github_repo
    check_gh_cli
    check_github_auth

    # Check what exists
    local has_local=false
    local has_remote=false
    local has_release=false

    if git rev-parse "$version" >/dev/null 2>&1; then
        has_local=true
    fi

    if git ls-remote --tags "$GIT_REMOTE" | grep -q "refs/tags/$version"; then
        has_remote=true
    fi

    if [ "$USE_GH_CLI" = true ]; then
        # Check for any release (including drafts and pre-releases)
        if gh api "repos/$GITHUB_REPO/releases/tags/$version" >/dev/null 2>&1; then
            has_release=true
        fi
    else
        # Check via API
        if [ -n "$GITHUB_TOKEN" ]; then
            local api_response=$(curl -s -H "Authorization: token $GITHUB_TOKEN" \
                "https://api.github.com/repos/$GITHUB_REPO/releases/tags/$version")
            if ! echo "$api_response" | grep -q '"message": "Not Found"'; then
                has_release=true
            fi
        fi
    fi

    if [ "$has_local" = false ] && [ "$has_remote" = false ] && [ "$has_release" = false ]; then
        error "Version $version not found (not in local, remote, or GitHub releases)"
    fi

    if [ "$DRY_RUN" = true ]; then
        echo -e "${Byellow}=== DRY RUN MODE ===${reset}"
        echo -e "${Bred}Would delete:${reset}"
        [ "$has_local" = true ] && echo "  ✓ Local tag: $version"
        [ "$has_remote" = true ] && echo "  ✓ Remote tag: $version (on $GIT_REMOTE)"
        [ "$has_release" = true ] && echo "  ✓ GitHub release: $version"
        echo ""
        echo -e "${Bwhite}Commands that would be executed:${reset}"
        [ "$has_local" = true ] && echo "  git tag -d $version"
        [ "$has_remote" = true ] && echo "  git push $GIT_REMOTE :refs/tags/$version"
        [ "$has_release" = true ] && echo "  gh release delete $version --repo $GITHUB_REPO --yes"
        return 0
    fi

    # Confirm deletion
    echo -e "${Bred}This will delete:${reset}"
    [ "$has_local" = true ] && echo "  • Local tag: $version"
    [ "$has_remote" = true ] && echo "  • Remote tag: $version (on $GIT_REMOTE)"
    [ "$has_release" = true ] && echo "  • GitHub release: $version"
    echo ""
    confirm "Delete release $version?"

    # Delete GitHub release first (including drafts and pre-releases)
    if [ "$has_release" = true ]; then
        log "Deleting GitHub release (including drafts): $version"
        if [ "$USE_GH_CLI" = true ]; then
            # gh release delete works for all release types
            gh release delete "$version" --repo "$GITHUB_REPO" --yes
            info "Deleted GitHub release: $version"
        else
            # API fallback - works for all release types
            local release_id=$(curl -s -H "Authorization: token $GITHUB_TOKEN" \
                "https://api.github.com/repos/$GITHUB_REPO/releases/tags/$version" | \
                grep '"id":' | head -1 | sed 's/[^0-9]*//g')

            if [ -n "$release_id" ]; then
                curl -s -X DELETE -H "Authorization: token $GITHUB_TOKEN" \
                    "https://api.github.com/repos/$GITHUB_REPO/releases/$release_id" >/dev/null
                info "Deleted GitHub release: $version"
            fi
        fi
    fi

    # Delete remote tag
    if [ "$has_remote" = true ]; then
        log "Deleting remote tag: $version"
        git push "$GIT_REMOTE" ":refs/tags/$version"
        info "Deleted remote tag: $version"
    fi

    # Delete local tag
    if [ "$has_local" = true ]; then
        log "Deleting local tag: $version"
        git tag -d "$version"
        info "Deleted local tag: $version"
    fi

    info "Successfully deleted release: $version"
}

# Show release details
cmd_show() {
    local version="$1"

    if [ -z "$version" ]; then
        error "Version required. Usage: $(basename "$0") show <version>"
    fi

    validate_version "$version"
    check_git_repo
    detect_github_repo
    check_gh_cli

    echo -e "${Bwhite}Release: $version${reset}"
    echo ""

    # Show local tag info
    if git rev-parse "$version" >/dev/null 2>&1; then
        echo -e "${Bgreen}Local Tag:${reset}"
        git show "$version" --no-patch --format="  Commit: %H%n  Author: %an <%ae>%n  Date: %ai%n  Message:%n    %s%n" | head -10
        echo ""
    else
        echo -e "${Byellow}Local tag not found${reset}"
        echo ""
    fi

    # Show remote tag info
    check_remote_exists
    if git ls-remote --tags "$GIT_REMOTE" | grep -q "refs/tags/$version"; then
        echo -e "${Bcyan}Remote Tag (${GIT_REMOTE}):${reset}"
        local remote_hash=$(git ls-remote --tags "$GIT_REMOTE" | grep "refs/tags/$version" | grep -v '\^{}' | awk '{print $1}')
        echo "  Commit: $remote_hash"
        echo ""
    else
        echo -e "${Byellow}Remote tag not found${reset}"
        echo ""
    fi

    # Show GitHub release info (including drafts and pre-releases)
    if [ "$USE_GH_CLI" = true ]; then
        if gh api "repos/$GITHUB_REPO/releases/tags/$version" >/dev/null 2>&1; then
            echo -e "${Bblue}GitHub Release:${reset}"
            gh release view "$version" --repo "$GITHUB_REPO" 2>/dev/null || \
                gh api "repos/$GITHUB_REPO/releases/tags/$version" --jq '.name, .tag_name, .draft, .prerelease, .created_at'
        else
            echo -e "${Byellow}GitHub release not found${reset}"
        fi
    else
        check_github_auth
        echo -e "${Bblue}GitHub Release:${reset}"
        local api_url="https://api.github.com/repos/$GITHUB_REPO/releases/tags/$version"
        local response=$(curl -s -H "Authorization: token $GITHUB_TOKEN" "$api_url")

        if echo "$response" | grep -q '"message": "Not Found"'; then
            echo -e "${Byellow}GitHub release not found${reset}"
        else
            echo "$response" | grep -E '"(name|tag_name|created_at|published_at|draft|prerelease)"' | \
                sed 's/^[[:space:]]*/  /'
        fi
    fi
}

# Parse command line arguments
if [ $# -eq 0 ]; then
    usage
fi

# First pass: extract command and global options
while [[ $# -gt 0 ]]; do
    case $1 in
        list|create|delete|show)
            COMMAND="$1"
            shift
            break
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --force)
            FORCE=true
            shift
            ;;
        --verbose)
            VERBOSE=true
            shift
            ;;
        --repo)
            GITHUB_REPO="$2"
            shift 2
            ;;
        --remote-name)
            GIT_REMOTE="$2"
            shift 2
            ;;
        -h|--help)
            usage
            ;;
        *)
            error "Unknown option: $1. Use --help for usage information."
            ;;
    esac
done

if [ -z "$COMMAND" ]; then
    error "No command specified. Use --help for usage information."
fi

# Initialize GitHub CLI detection
check_gh_cli

# Execute command with remaining arguments
case $COMMAND in
    list)
        cmd_list "$@"
        ;;
    create)
        # Parse create-specific options
        version=""
        message=""
        while [[ $# -gt 0 ]]; do
            case $1 in
                -m|--message)
                    message="$2"
                    shift 2
                    ;;
                *)
                    if [ -z "$version" ]; then
                        version="$1"
                    elif [ -z "$message" ]; then
                        message="$1"
                    fi
                    shift
                    ;;
            esac
        done
        cmd_create "$version" "$message"
        ;;
    delete)
        cmd_delete "$1"
        ;;
    show)
        cmd_show "$1"
        ;;
    *)
        error "Unknown command: $COMMAND"
        ;;
esac
