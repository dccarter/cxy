
func showField[NAME, T](obj: &const T) {
    #const field = T.members.[NAME.value]
    println(#{NAME.value}, " = ", obj.#{mk_ident!(NAME.value)})
}

struct User {
    name: string = "Jane"
    age: i32 = 0
    func `init`(a: i32){ age = a}
}

func main(): !void {
    #if (User.hasInit) {
        println("We have init")
    }
    #if (User.hasDefaultInit) {
        println("We have default init")
    }
}
