#!/bin/bash
# cxy-check-updates
#
# Cxy version update checker
# Checks for patch updates within the same major.minor version

set -euo pipefail

# Color definitions (matching download-cxy.sh)
reset='\033[0m'           # Text Reset
red='\033[0;31m'          # Red
green='\033[0;32m'        # Green
yellow='\033[0;33m'       # Yellow
blue='\033[0;34m'         # Blue
cyan='\033[0;36m'         # Cyan
white='\033[0;37m'        # White

# Bold
Bred='\033[1;31m'         # Red
Bgreen='\033[1;32m'       # Green
Byellow='\033[1;33m'      # Yellow
Bblue='\033[1;34m'        # Blue
Bcyan='\033[1;36m'        # Cyan
Bwhite='\033[1;37m'       # White

# Configuration
GITHUB_REPO="${CXY_GITHUB_REPO:-dccarter/cxy}"
LOG_FILE="${CXY_LOG_FILE:-/var/log/cxy-updates.log}"
CXY_BIN="${CXY_BIN:-cxy}"
DOWNLOAD_SCRIPT="${CXY_DOWNLOAD_SCRIPT:-}"

# Parse arguments
DRY_RUN=false
VERBOSE=false
AUTO_UPDATE=false

usage() {
    cat << EOF
Usage: $(basename "$0") [OPTIONS]

Check for Cxy version updates on GitHub.

OPTIONS:
    --dry-run       Show what would happen without making changes
    --verbose       Show detailed output
    --auto-update   Automatically download and install updates
    -h, --help      Show this help message

ENVIRONMENT VARIABLES:
    CXY_GITHUB_REPO      GitHub repository (default: dccarter/cxy)
    CXY_LOG_FILE         Log file path (default: /var/log/cxy-updates.log)
    CXY_BIN              Cxy binary path (default: cxy)
    CXY_DOWNLOAD_SCRIPT  Path to download-cxy.sh script (auto-detected if not set)

EXAMPLES:
    $(basename "$0") --dry-run
    $(basename "$0") --verbose
    CXY_GITHUB_REPO="owner/repo" $(basename "$0")

EXIT CODES:
    0    Up to date (no updates available)
    1    Update available
    2    Error occurred
EOF
    exit 0
}

log() {
    local message="$1"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')

    if [ "$VERBOSE" = true ]; then
        echo "[$timestamp] $message"
    fi

    if [ "$DRY_RUN" = false ]; then
        echo "[$timestamp] $message" >> "$LOG_FILE" 2>/dev/null || true
    fi
}

error() {
    echo -e "${Bred}error${reset}: $1" >&2
    log "ERROR: $1"
    exit 2
}

# Parse command line arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --dry-run)
            DRY_RUN=true
            VERBOSE=true
            shift
            ;;
        --verbose)
            VERBOSE=true
            shift
            ;;
        --auto-update)
            AUTO_UPDATE=true
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            error "Unknown option: $1"
            ;;
    esac
done

# Check dependencies
for cmd in curl grep; do
    if ! command -v "$cmd" &> /dev/null; then
        error "Required command not found: $cmd"
    fi
done

# Check for jq (optional but recommended)
HAS_JQ=false
if command -v jq &> /dev/null; then
    HAS_JQ=true
fi

# Auto-detect download script if not set
if [ -z "$DOWNLOAD_SCRIPT" ]; then
    # Try to find cxy-download relative to this script
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    if [ -f "$SCRIPT_DIR/cxy-download" ]; then
        DOWNLOAD_SCRIPT="$SCRIPT_DIR/cxy-download"
    fi
fi

if [ "$DRY_RUN" = true ]; then
    echo -e "${Byellow}=== DRY RUN MODE ===${reset}"
    echo -e "${Bblue}GitHub Repo:${reset} $GITHUB_REPO"
    echo -e "${Bblue}Log File:${reset} $LOG_FILE"
    echo -e "${Bblue}Cxy Binary:${reset} $CXY_BIN"
    echo -e "${Bblue}Has jq:${reset} $HAS_JQ"
    echo -e "${Bblue}Auto-update:${reset} $AUTO_UPDATE"
    echo -e "${Bblue}Download Script:${reset} ${DOWNLOAD_SCRIPT:-not found}"
    echo ""
fi

# Get current version
if ! command -v "$CXY_BIN" &> /dev/null; then
    error "Cxy binary not found: $CXY_BIN"
fi

VERSION_OUTPUT=$("$CXY_BIN" --version 2>/dev/null) || error "Failed to get cxy version"
log "Version output: $VERSION_OUTPUT"

# Extract version (e.g., "cxy v0.1.0 (build: 0, Mar  6 2026, 05:15:00)" -> "v0.1.0")
CURRENT_VERSION=$(echo "$VERSION_OUTPUT" | sed -n 's/.*\(v[0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*\).*/\1/p' | head -1)

if [ -z "$CURRENT_VERSION" ]; then
    error "Could not parse version from: $VERSION_OUTPUT"
fi

log "Current version: $CURRENT_VERSION"

# Extract major.minor (e.g., "v0.1.0" -> "v0.1")
MAJOR_MINOR=$(echo "$CURRENT_VERSION" | sed -n 's/\(v[0-9][0-9]*\.[0-9][0-9]*\)\.[0-9][0-9]*/\1/p')

# Extract patch number (e.g., "v0.1.0" -> "0")
CURRENT_PATCH=$(echo "$CURRENT_VERSION" | sed -n 's/.*\.\([0-9][0-9]*\)$/\1/p')

if [ -z "$MAJOR_MINOR" ] || [ -z "$CURRENT_PATCH" ]; then
    error "Could not parse version components from: $CURRENT_VERSION"
fi

log "Checking for updates in series: ${MAJOR_MINOR}.*"

# Fetch releases from GitHub
GITHUB_API="https://api.github.com/repos/$GITHUB_REPO/releases"
log "Fetching releases from: $GITHUB_API"

# Create temp file
TEMP_FILE=$(mktemp)
trap "rm -f $TEMP_FILE" EXIT

# Try with GitHub API
HTTP_CODE=$(curl -s -w "%{http_code}" -o "$TEMP_FILE" "$GITHUB_API" 2>/dev/null || echo "000")

if [ "$HTTP_CODE" != "200" ]; then
    error "Failed to fetch releases from GitHub (HTTP $HTTP_CODE). Check repository name and network connectivity."
fi

# Parse release tags
if [ "$HAS_JQ" = true ]; then
    # Use jq for reliable JSON parsing - get tag_name from releases
    TAGS=$(jq -r '.[].tag_name' "$TEMP_FILE" 2>/dev/null) || error "Failed to parse GitHub response"
else
    # Fallback to sed (works without jq) - extract tag_name field
    TAGS=$(sed -n 's/.*"tag_name":[[:space:]]*"\([^"]*\)".*/\1/p' "$TEMP_FILE" 2>/dev/null) || error "Failed to parse GitHub response"
fi

# Filter release tags matching our major.minor series
MATCHING_TAGS=$(echo "$TAGS" | grep "^${MAJOR_MINOR}\." || true)

if [ -z "$MATCHING_TAGS" ]; then
    log "No releases found for series ${MAJOR_MINOR}.*"
    echo -e "${Bgreen}✓${reset} No updates available (current: $CURRENT_VERSION)"
    exit 0
fi

log "Found releases in series: $(echo "$MATCHING_TAGS" | tr '\n' ' ')"

# Find the newest patch version
NEWEST_PATCH=$CURRENT_PATCH
NEWEST_TAG=$CURRENT_VERSION

while IFS= read -r tag; do
    # Extract patch number from tag (e.g., "v0.1.5" -> "5")
    PATCH=$(echo "$tag" | sed -n 's/.*\.\([0-9][0-9]*\)$/\1/p')

    if [ -n "$PATCH" ] && [ "$PATCH" -gt "$NEWEST_PATCH" ]; then
        NEWEST_PATCH=$PATCH
        NEWEST_TAG=$tag
    fi
done <<< "$MATCHING_TAGS"

# Compare versions and report
if [ "$NEWEST_PATCH" -gt "$CURRENT_PATCH" ]; then
    MESSAGE="Update available: $NEWEST_TAG (current: $CURRENT_VERSION)"

    echo -e "${Bgreen}✓${reset} ${Bcyan}$MESSAGE${reset}"
    log "$MESSAGE"

    if [ "$DRY_RUN" = true ]; then
        echo ""
        echo -e "${Bwhite}Actions that would be taken:${reset}"
        echo -e "  ${Bblue}•${reset} Log to: $LOG_FILE"
        echo -e "  ${Bblue}•${reset} Message: $MESSAGE"
        if [ "$AUTO_UPDATE" = true ]; then
            if [ -n "$DOWNLOAD_SCRIPT" ] && [ -f "$DOWNLOAD_SCRIPT" ]; then
                echo -e "  ${Bblue}•${reset} Run: ${Bcyan}RELEASE_TAG=$NEWEST_TAG $DOWNLOAD_SCRIPT${reset}"
            else
                echo -e "  ${Byellow}⚠${reset} Auto-update requested but download script not found"
            fi
        fi
    elif [ "$AUTO_UPDATE" = true ]; then
        # Perform automatic update
        if [ -z "$DOWNLOAD_SCRIPT" ] || [ ! -f "$DOWNLOAD_SCRIPT" ]; then
            error "Auto-update requested but download script not found at: ${DOWNLOAD_SCRIPT:-<not set>}"
        fi

        echo ""
        echo -e "${Bgreen}Starting automatic update to $NEWEST_TAG...${reset}"
        log "Starting automatic update to $NEWEST_TAG"

        # Run the download script with the new version
        RELEASE_TAG="$NEWEST_TAG" "$DOWNLOAD_SCRIPT"
        result=$?

        if [ $result -eq 0 ]; then
            echo -e "${Bgreen}✓ Successfully updated to $NEWEST_TAG${reset}"
            log "Successfully updated to $NEWEST_TAG"
        else
            error "Update failed with exit code $result"
        fi
    fi

    # Exit code 1 indicates update available (useful for scripts)
    exit 1
else
    MESSAGE="Already running latest version: $CURRENT_VERSION"

    echo -e "${Bgreen}✓${reset} $MESSAGE"
    log "$MESSAGE"

    if [ "$DRY_RUN" = true ]; then
        echo ""
        echo -e "${Bwhite}No actions needed.${reset}"
    fi

    # Exit code 0 indicates up to date
    exit 0
fi
